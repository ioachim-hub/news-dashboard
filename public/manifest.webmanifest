{
  "name": "News Dashboard",
  "short_name": "News",
  "description": "Personal AI-curated news dashboard",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#faf8f5",
  "theme_color": "#221f1a",
  "lang": "en",
  "icons": [
    {
      "src": "/favicon.svg",
